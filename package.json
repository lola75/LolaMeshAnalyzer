{
  "name": "mesh-analyzer",
  "version": "1.0.0",
  "description": "Web app for analyzing and visualizing 3D mesh files (STL, OBJ, PLY)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "local": "npm run dev",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js,.jsx",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "electron-build": "npm run build && set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder",
    "server": "node server.js",
    "start": "npm run build && npm run server",
    "deploy:vercel": "vercel deploy --prod",
    "deploy:local": "npm run build && node server.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "three": "^0.158.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.0",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0",
    "wait-on": "^7.0.1"
  },
  "main": "public/main.js",
  "homepage": "./",
  "build": {
    "appId": "com.isdidegs.meshanalyzer",
    "productName": "Analizzatore di Mesh 3D",
    "files": [
      "dist/**/*",
      "public/main.js",
      "public/preload.js",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Analizzatore di Mesh 3D"
    },
    "portable": {
      "artifactName": "Mesh-Analyzer-${version}.exe"
    }
  }
}
